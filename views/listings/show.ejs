<%# Replace: views/listings/show.ejs %>
<% layout("layouts/boilerplate") %>

<div class="row mt-3 g-3">

  <%# TITLE %>
  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">
    <h3 class="fw-bold"><%=listing.title%></h3>
  </div>

  <%# LISTING CARD %>
  <div class="col-12 col-md-10 offset-md-1 col-lg-6 offset-lg-3">
    <div class="card show-card listing-card">
      <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing image">
      <div class="card-body px-3 py-3">
        <p class="text-muted mb-1"><i>Owned by: <%= listing.owner ? listing.owner.username : "Unknown" %></i></p>
        <hr>
        <p><%=listing.description%></p>
        <p class="fw-semibold">&#8377;<%=listing.price%> / night</p>
        <p class="mb-1 text-muted"><i class="fa-solid fa-location-dot me-1" style="color:var(--brand)"></i><%=listing.location%>, <%=listing.country%></p>
      </div>
    </div>
  </div>

  <%# MAP %>
  <% if (mapCoordinates) { %>
    <div class="col-12 col-md-10 offset-md-1 col-lg-6 offset-lg-3 mb-3">
      <h5 class="fw-semibold mb-2">Where you'll be</h5>
      <div id="map"></div>
    </div>
  <% } %>

  <%# EDIT / DELETE BUTTONS — only owner %>
  <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)){ %>
    <div class="col-12 col-md-10 offset-md-1 col-lg-6 offset-lg-3">
      <div class="btns">
        <a href="/listings/<%=listing._id%>/edit" class="btn edit-btn">
          <i class="fa-solid fa-pen me-1"></i>Edit
        </a>
        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
          <button class="btn btn-outline-dark">
            <i class="fa-solid fa-trash me-1"></i>Delete
          </button>
        </form>
      </div>
    </div>
  <% } %>

  <%# REVIEW FORM %>
  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2 mt-2">

    <% if(currUser){ %>
      <h4 class="fw-semibold mb-3">Leave Your Review</h4>
      <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation mb-4">

        <div class="mb-3">
          <label class="form-label fw-medium">Rating</label>
          <fieldclass="starability-slot">
          <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating."/>
            <input type="radio" id="first-rate1" name="review[rating]" value="1"/>
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2"/>
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3"/>
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4"/>
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5"/>
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>

        <div class="mb-3">
          <label for="comment" class="form-label fw-medium">Comments</label>
          <textarea name="review[comment]" id="comment" class="form-control" rows="3" required></textarea>
          <div class="invalid-feedback">Please add a comment for your review.</div>
        </div>

        <button class="btn btn-outline-dark">Submit Review</button>
      </form>
    <% } %>

    <hr>
    <h5 class="fw-semibold mb-3">All Reviews</h5>

    <% if(listing.reviews.length === 0){ %>
      <p class="text-muted">No reviews yet. Be the first!</p>
    <% } %>

    <div class="row g-3">
      <% for(let review of listing.reviews){ %>
        <div class="col-12 col-sm-6 col-lg-5">
          <div class="card review-card h-100">
            <div class="card-body">
              <h6 class="card-title fw-semibold mb-1">@<%= review.author ? review.author.username : "Unknown" %></h6>
              <p class="starability-result mb-2" data-rating="<%=review.rating%>"></p>
              <p class="card-text text-muted mb-2"><%=review.comment%></p>
              <% if(currUser){ %>
                <form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                  <button class="btn btn-sm btn-dark">Delete</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>
    </div>

    <br>
  </div>
</div>

<% if (mapCoordinates) { %>
  <link href="https://unpkg.com/maplibre-gl/dist/maplibre-gl.css" rel="stylesheet"/>
  <script src="https://unpkg.com/maplibre-gl/dist/maplibre-gl.js"></script>
  <script>
    const mapCoordinates = <%- JSON.stringify(mapCoordinates) %>;
    const popupText = <%- JSON.stringify([listing.location, listing.country].filter(Boolean).join(", ")) %>;
    const map = new maplibregl.Map({
      container: "map",
      style: "https://tiles.openfreemap.org/styles/liberty",
      center: mapCoordinates,
      zoom: 9,
    });
    map.addControl(new maplibregl.NavigationControl());
    new maplibregl.Marker()
      .setLngLat(mapCoordinates)
      .setPopup(new maplibregl.Popup().setText(popupText))
      .addTo(map);
  </script>
<% } %>
