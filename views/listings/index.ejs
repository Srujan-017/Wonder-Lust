<%# Replace: views/listings/index.ejs %>
<% layout("layouts/boilerplate") %>

<body>
  <%# ── CATEGORY FILTERS ── %>
  <div id="filters">
    <a href="/listings?category=trending<%= search ? '&search=' + encodeURIComponent(search) : '' %>"
       class="filter <%= category === 'trending' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-fire"></i></div><p>Trending</p>
    </a>
    <a href="/listings?category=room<%= search ? '&search=' + encodeURIComponent(search) : '' %>"
       class="filter <%= category === 'room' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-bed"></i></div><p>Room</p>
    </a>
    <a href="/listings?category=iconic-cities<%= search ? '&search=' + encodeURIComponent(search) : '' %>"
       class="filter <%= category === 'iconic-cities' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-city"></i></div><p>Iconic cities</p>
    </a>
    <a href="/listings?category=mountains<%= search ? '&search=' + encodeURIComponent(search) : '' %>"
       class="filter <%= category === 'mountains' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-mountain-city"></i></div><p>Mountains</p>
    </a>
    <a href="/listings?category=castle<%= search ? '&search=' + encodeURIComponent(search) : '' %>"
       class="filter <%= category === 'castle' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-igloo"></i></div><p>Castle</p>
    </a>
    <a href="/listings?category=pools<%= search ? '&search=' + encodeURIComponent(search) : '' %>"
       class="filter <%= category === 'pools' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-person-swimming"></i></div><p>Amazing pools</p>
    </a>
    <a href="/listings?category=camping<%= search ? '&search=' + encodeURIComponent(search) : '' %>"
       class="filter <%= category === 'camping' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-mountain"></i></div><p>Camping</p>
    </a>
    <a href="/listings?category=farms<%= search ? '&search=' + encodeURIComponent(search) : '' %>"
       class="filter <%= category === 'farms' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-warehouse"></i></div><p>Farms</p>
    </a>
    <a href="/listings?category=arctic<%= search ? '&search=' + encodeURIComponent(search) : '' %>"
       class="filter <%= category === 'arctic' ? 'active-filter' : '' %>">
      <div><i class="fa-regular fa-snowflake"></i></div><p>Arctic</p>
    </a>

    <div class="tax-toggle ms-auto">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="taxSwitch">
        <label class="form-check-label" for="taxSwitch">Show taxes</label>
      </div>
    </div>
  </div>

  <%# CLEAR FILTERS LINK %>
  <% if(search || category){ %>
    <div class="mt-2 mb-1">
      <a href="/listings" class="btn btn-sm btn-outline-dark">
        <i class="fa-solid fa-xmark me-1"></i>Clear filters
      </a>
    </div>
  <% } %>

  <%# LISTING GRID %>
  <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 mt-3 g-3">
    <% for(let listing of allListings){ %>
      <div class="col">
        <a href="/listings/<%= listing.id %>" class="listing-link">
          <div class="card listing-card h-100">
            <img
              src="<%=listing.image.url%>"
              class="card-img-top"
              alt="<%=listing.title%>"
              loading="lazy">
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <p class="card-text">
                <b><%=listing.title%></b><br>
                <span class="text-muted" style="font-size:0.9rem;">
                  <%=listing.location%>, <%=listing.country%>
                </span><br>
                <span class="fw-semibold">&#8377;<%=listing.price%></span>
                <span> / night</span>
                <i class="tax-info text-muted" style="font-size:0.82rem;">&nbsp;+18% GST</i>
              </p>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>

  <% if(allListings.length === 0){ %>
    <div class="text-center mt-5 no-listing">
      <i class="fa-solid fa-magnifying-glass fa-2x mb-3"></i>
      <h4>No listings found</h4>
      <p>Try a different search or category.</p>
      <a href="/listings" class="btn btn-dark mt-2">Browse all</a>
    </div>
  <% } %>

</body>

<script>
  const taxSwitch = document.getElementById("taxSwitch");
  taxSwitch.addEventListener("change", () => {
    document.querySelectorAll(".tax-info").forEach(el => {
      el.style.display = taxSwitch.checked ? "inline" : "none";
    });
  });
</script>
