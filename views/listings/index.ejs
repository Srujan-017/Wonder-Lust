<% layout("layouts/boilerplate") %>

  <body>
    <style>
      #filters {
        display: flex;
        flex-wrap: wrap;
        align-items:center;
      }

      .filter {
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
        color: #222222;
        text-decoration: none;
      }

      .filter:hover {
        opacity: 1;
        cursor: pointer;
      }

      .active-filter {
        opacity: 1;
        color: #fe424d;
      }

      .filter p {
        font-size: 0.8rem;
      }
      .tax-info{
        display:none;
      }
      .tax-toggle{
        border: 1px solid black;
        height:3.5rem;
        border-radius: 1rem;
        padding: 1rem;
        margin-left:2rem;
        display:flex;
        align-items: center;
      }
    </style>
    <!--<h3>All listing </h3>-->
    <!-- <form method="GET" action="/listings/new">
        <button>Create New Listing</button>
    </form> -->
    <div id="filters">
      <a href="/listings?category=trending<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter <%= category === 'trending' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
      </a>
      <a href="/listings?category=room<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter <%= category === 'room' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Room</p>
      </a>

      <a href="/listings?category=iconic-cities<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter <%= category === 'iconic-cities' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-city"></i></div>
        <p>Iconic cities</p>
      </a>
      <a href="/listings?category=mountains<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter <%= category === 'mountains' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Mountains</p>
      </a>

      <a href="/listings?category=castle<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter <%= category === 'castle' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Castle</p>
      </a>
      <a href="/listings?category=pools<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter <%= category === 'pools' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing pools</p>
      </a>
      <a href="/listings?category=camping<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter <%= category === 'camping' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Camping</p>
      </a>

      <a href="/listings?category=farms<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter <%= category === 'farms' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-warehouse"></i></div>
        <p>Farms</p>
      </a>
      <a href="/listings?category=arctic<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter <%= category === 'arctic' ? 'active-filter' : '' %>">
        <div><i class="fa-regular fa-snowflake"></i></div>
        <p>Arctic</p>
      </a>

      

      <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
          <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
        </div>
      </div>
    </div>

    <% if(search || category){ %>
      <div class="mt-3">
        <a href="/listings" class="btn btn-sm btn-outline-dark">Clear filters</a>
      </div>
    <% } %>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3"> <!--minimum 3 card dehiye de-->
      <%for(let listing of allListings){%>
        <a href="/listings/<%= listing.id %> " class="listing-link">
          <div class="card cols  listing-card">
            <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image" style="height: 20rem;">
            <div class="card-img-overlay"></div>

            <div class="card-body">
              <p class="card-text">
                <b>
                  <%=listing.title %>
                </b><br>
                &#8377;<%=listing.price %> / night
                <i class="tax-info"> &nbsp; &nbsp;+18% GST</i>
              </p>
            </div>
          </div>
        </a>

        <%}%>
    </div>

    <% if(allListings.length === 0){ %>
      <h4 class="mt-4 text-center">No listings found</h4>
    <% } %>

  </body>
  <script>
 let taxSwitch=document.getElementById("flexSwitchCheckDefault");
 taxSwitch.addEventListener("click",()=>{
  let  taxInfo =document.getElementsByClassName("tax-info");
  for(info of taxInfo){
    if(info.style.display !="inline"){
      info.style.display="inline";
    }else{
      info.style.display="none";
    }
    
  }
  
 })
  </script>
